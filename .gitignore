# Repo-local sandbox rootfs cache (squashfs files + squashfuse mountpoints).
# Created by `just sandbox-fetch` / `just sandbox-build`; never committed.
.ziee-cache/

# Ad-hoc local test-run logs (E2E + integration + audit tee output).
*.log

# Local test-environment secrets (API keys for integration tests).
# Sourced by `just test` via tests/.env.test; never committed.
**/.env.test

# Cross-compile target dir for sandbox-guest-agent (built inside an
# aarch64-musl Docker container so the host Mac can produce the in-VM agent
# binary). Cargo doesn't auto-place a .gitignore here because the path is
# custom (CARGO_TARGET_DIR), so ignore it explicitly.
target-docker/

# Local dev config (machine-specific paths)
src-app/server/config/dev.yaml
