# Repo-local sandbox rootfs cache (squashfs files + squashfuse mountpoints).
# Created by `just sandbox-fetch` / `just sandbox-build`; never committed.
.ziee-cache/

# Runtime app-data dir (server-extracted bin tools: bun/pandoc/uv/pdfium,
# hub catalog seed, postgres data). Created when running the server with the
# default dev config's `data_dir: ../../ziee-data/...`; never committed.
ziee-data/
ziee-chat-data/

# Ad-hoc local test-run logs (E2E + integration + audit tee output).
*.log

# Local test-environment secrets (API keys for integration tests).
# Sourced by `just test` via tests/.env.test; never committed.
**/.env.test

# Local-only credentials for Tier 8 real-ngrok integration tests.
# Sourced by `just check-remote-access-real-ngrok`; never committed.
.ngrok-test-credentials.env

# Cross-compile target dir for sandbox-guest-agent (built inside an
# aarch64-musl Docker container so the host Mac can produce the in-VM agent
# binary). Cargo doesn't auto-place a .gitignore here because the path is
# custom (CARGO_TARGET_DIR), so ignore it explicitly.
target-docker/

# Local dev config (machine-specific paths)
src-app/server/config/dev.yaml

# npm workspaces hoists into the repo-root node_modules; never committed.
node_modules/
# In a git worktree the hoisted node_modules is a SYMLINK to the main checkout,
# which the trailing-slash dir pattern above does not match — anchor it too.
/node_modules

# Playwright artifacts — per-run, never committed.
playwright-report/
test-results/

# pgvector build-helper outputs that land inside the vendored
# submodule dir (downloaded PG binaries + the SDK wrapper script).
# Regenerated on every `cargo build` of the server crate.
src-app/server/vendor/pgvector/postgresql-*/
src-app/server/vendor/pgvector/pg_config_wrapper/

# macOS Finder cruft.
.DS_Store

# Output of the updater Pages CI test (`just check-updater-ci` via act --bind).
.updater-test-out/

# Claude Code local state + docs — never tracked (settings, agents,
# worktrees, scheduled-task lock, and any architecture notes under here).
# .claude is machine-local EXCEPT the committed agent infra below
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/feature-lifecycle/
!.claude/skills/feature-orchestration/
!.claude/skills/design-variant-tournament/
!.claude/skills/shadcn-component-discovery/
!.claude/skills/shadcn-component-review/
!.claude/skills/frontend-ui-engineering/
!.claude/skills/design-taste-frontend/
!.claude/lifecycle/

# Transient server build/packaging staging (server-release.yml + nfpm smoke).
/dist/

# --- Local / diagnostic artifacts: kept on disk, never tracked ---
# Audit reports (round-by-round reports at repo root + .audit/ outputs).
/AUDIT-*.md
.audit/
# Test logs + antd diagnostic dumps roll over naturally; don't commit them.
src-app/server/test-logs/
src-app/ui/docs/antd-diagnostics/
src-app/target
