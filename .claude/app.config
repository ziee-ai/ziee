# ziee's agent-kit app.config — consumed by .claude/lifecycle/{preflight.sh,merge-gate.mjs}
# (symlinks into the agent-kit submodule). Plain KEY=value; READ, never sourced.
# Every key is optional; an unset key makes its check/gate SKIP. See
# agent-kit/app.config.example for the full contract.

# ── preflight.sh (Phase-1 environment gate) ───────────────────────────────
PREFLIGHT_SEED_FILE=src-app/server/binaries/hub-seed/index.json
PREFLIGHT_SEED_HINT=rm -rf src-app/server/binaries/hub-seed && cargo check -p ziee (refetch from GitHub), or cp it from a clone that has it
PREFLIGHT_SUBMODULE=src-app/server/vendor/pgvector
PREFLIGHT_NODE_WORKSPACES=src-app/ui src-app/desktop/ui
PREFLIGHT_BUILD_DB_ENV=ZIEE_BUILD_DB_PERWORKTREE
PREFLIGHT_BUILD_DB_HOSTPORT=127.0.0.1:54321
PREFLIGHT_BUILD_DB_SENTINEL=sqlx-build-sentinel
PREFLIGHT_CONFIG_DIR=src-app/server/config
PREFLIGHT_CONFIG_FILE=dev.yaml
PREFLIGHT_CONFIG_EXAMPLE=dev.example.yaml
PREFLIGHT_CONFIG_PLACEHOLDER=dev-secret-change-in-production-min-32-chars-long

# ── merge-gate.mjs (merge-time gate) ──────────────────────────────────────
MERGE_MIGRATIONS_DIR=src-app/server/migrations
MERGE_CARGO_PACKAGE=ziee
MERGE_CARGO_DIR=src-app
MERGE_CARGO_DESKTOP_PACKAGE=ziee-desktop
MERGE_DESKTOP_TOUCH_PREFIX=src-app/desktop/tauri/
MERGE_REGEN_CMD=just openapi-regen
MERGE_GENERATED=src-app/ui/openapi/openapi.json src-app/ui/src/api-client/types.ts src-app/desktop/ui/openapi/openapi.json src-app/desktop/ui/src/api-client/types.ts

# ── lifecycle-check.mjs (A2 clean-tree gate) ──────────────────────────────
# Path substrings whose working-tree status the A2 clean-tree gate ignores.
# `sdk` covers the kit submodule's GENERATED testid registry
# (sdk/packages/kit/src/testIds.generated.ts): features that add kit
# data-testids regenerate it, but the sdk POINTER stays unchanged (9e6d8c74 on
# both base + HEAD) and the regen must be committed INTO the sdk submodule +
# pointer-bumped at MERGE time (cross-repo, human-coordinated — see
# CROSS_REPO.md). git reports submodule dirtiness at the `sdk` path granularity,
# not the inner file, so the ignore is the submodule path. (cli.mjs and any
# other sdk edit are reverted, so the only expected sdk dirt is that registry.)
LIFECYCLE_CLEAN_TREE_IGNORE=vendor/pgvector sdk
