[submodule "src-app/server/vendor/pgvector"]
	path = src-app/server/vendor/pgvector
	url = https://github.com/pgvector/pgvector.git
	branch = master
[submodule "sdk"]
	path = sdk
	url = https://github.com/ziee-ai/sdk.git
	# ziee (the "chat" app) normally pins the SDK to its dedicated branch `chat`
	# (CytoAnalyst pins `cyto`). While the agent-core + frontend-perf integration
	# is in flight this pins the COMBINED branch `sdk/agent-core-and-perf` (which
	# extends the agent-core SDK line with frontend-perf's kit changes + the
	# post-merge testid regen); reconcile it back into `chat` once landed.
	branch = sdk/agent-core-and-perf
[submodule "agent-kit"]
	path = agent-kit
	url = https://github.com/ziee-ai/agent-kit.git
