[submodule "src-app/server/vendor/pgvector"]
	path = src-app/server/vendor/pgvector
	url = https://github.com/pgvector/pgvector.git
	branch = master
[submodule "sdk"]
	path = sdk
	url = https://github.com/ziee-ai/sdk.git
	# ziee tracks its deploy-dedicated SDK branch `biognosia-sdk` (cut from `chat`).
	# SDK changes for ziee PR into `biognosia-sdk`; when `chat` advances, merge
	# chat → biognosia-sdk to pull them in. (CytoAnalyst pins `cyto`.)
	branch = biognosia-sdk
[submodule "agent-kit"]
	path = agent-kit
	url = https://github.com/ziee-ai/agent-kit.git
