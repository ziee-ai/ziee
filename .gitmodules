[submodule "src-app/server/vendor/pgvector"]
	path = src-app/server/vendor/pgvector
	url = git@github.com:pgvector/pgvector.git
	branch = master
[submodule "sdk"]
	path = sdk
	url = git@github.com:ziee-ai/sdk.git
	# DEPLOY LINE: tracks a deploy-dedicated SDK branch `biognosia-sdk` (cut from
	# `chat`). Deploy-only SDK changes PR into `biognosia-sdk`; when `chat`
	# advances, merge chat → biognosia-sdk to pull them in. (khoi/main track `chat`.)
	branch = biognosia-sdk
[submodule "agent-kit"]
	path = agent-kit
	url = git@github.com:ziee-ai/agent-kit.git
