[submodule "src-app/server/vendor/pgvector"]
	path = src-app/server/vendor/pgvector
	url = git@github.com:pgvector/pgvector.git
	branch = master
[submodule "sdk"]
	path = sdk
	url = git@github.com:ziee-ai/sdk.git
	# ziee (the "chat" app) pins the SDK to its own dedicated branch `chat`
	# (CytoAnalyst pins `cyto`). SDK changes made here push to sdk `chat`; when
	# sdk `main` advances, merge main → `chat` and decide whether to adopt.
	branch = chat
[submodule "agent-kit"]
	path = agent-kit
	url = git@github.com:ziee-ai/agent-kit.git
