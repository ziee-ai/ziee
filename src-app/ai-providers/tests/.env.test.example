# AI Provider API Keys for Testing
# Copy this file to .env.test and fill in your API keys

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Groq API Key (for OpenAI compatibility testing)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Note: All tests are marked with #[ignore] and will not run automatically
# Run specific provider tests with:
#   source tests/.env.test && cargo test --test test_openai -- --nocapture
#   source tests/.env.test && cargo test --test test_anthropic -- --nocapture
#   source tests/.env.test && cargo test --test test_gemini -- --nocapture
