{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.modelcontextprotocol/filesystem",
  "description": "Local filesystem access (read, write, search, list) over MCP. Stdio transport.",
  "version": "1.0.0",
  "repository": {
    "url": "https://github.com/modelcontextprotocol/servers",
    "source": "github",
    "subfolder": "src/filesystem"
  },
  "websiteUrl": "https://modelcontextprotocol.io/",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@modelcontextprotocol/server-filesystem",
      "version": "1.5.2",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "/path/to/allowed/files",
          "description": "Allowed root directory the MCP server can access.",
          "valueHint": "allowed_dir"
        }
      ]
    }
  ]
}
