{
  "$schema": "/schemas/2026-06-12/model.schema.json",
  "name": "io.github.ziee-ai/phi-3-mini-4k-instruct",
  "version": "1.0.0",
  "display_name": "Phi-3 Mini",
  "description": "Microsoft's small but capable instruction-tuned model. Great for low-resource setups.",
  "repository": {
    "url": "https://huggingface.co/microsoft/Phi-3-mini-4k-instruct",
    "source": "huggingface",
    "id": "microsoft/Phi-3-mini-4k-instruct"
  },
  "sources": [
    {
      "registryType": "huggingface",
      "identifier": "microsoft/Phi-3-mini-4k-instruct",
      "version": "main",
      "fileFormat": "safetensors",
      "runtimeHint": "mistralrs",
      "contextLength": 4096,
      "environmentVariables": [
        {
          "name": "HUGGINGFACE_API_KEY",
          "description": "Hugging Face access token with download access to this gated model.",
          "isSecret": true,
          "isRequired": true
        }
      ],
      "quantizations": [
        {
          "name": "f16",
          "mainFile": "model.safetensors",
          "sizeGb": 7.6,
          "isDefault": true
        }
      ]
    }
  ],
  "dependencies": [],
  "capabilities": {
    "chat": true,
    "tools": true,
    "vision": false,
    "audio": false,
    "text_embedding": false,
    "image_generator": false,
    "code_interpreter": true
  },
  "tags": [
    "instruct",
    "chat",
    "small",
    "efficient"
  ],
  "recommended_parameters": {
    "temperature": 0.6,
    "top_p": 0.95,
    "top_k": 50,
    "repeat_penalty": 1.05,
    "context_size": 4096
  },
  "language_support": [
    "en"
  ],
  "license": "MIT"
}
