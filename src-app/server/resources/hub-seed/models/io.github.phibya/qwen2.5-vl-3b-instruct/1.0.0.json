{
  "$schema": "/schemas/2026-06-12/model.schema.json",
  "name": "io.github.phibya/qwen2.5-vl-3b-instruct",
  "version": "1.0.0",
  "display_name": "Qwen2.5-VL 3B",
  "description": "Qwen2.5-VL 3B instruction-tuned vision-language model. Supports image understanding plus tool use.",
  "repository": {
    "url": "https://huggingface.co/Qwen/Qwen2.5-VL-3B-Instruct",
    "source": "huggingface",
    "id": "Qwen/Qwen2.5-VL-3B-Instruct"
  },
  "sources": [
    {
      "registryType": "huggingface",
      "identifier": "Qwen/Qwen2.5-VL-3B-Instruct",
      "version": "main",
      "fileFormat": "safetensors",
      "runtimeHint": "mistralrs",
      "contextLength": 32768,
      "environmentVariables": [
        {
          "name": "HUGGINGFACE_API_KEY",
          "description": "Hugging Face access token with download access to this gated model.",
          "isSecret": true,
          "isRequired": true
        }
      ],
      "quantizations": [
        {
          "name": "f16",
          "mainFile": "model.safetensors",
          "sizeGb": 6.2,
          "isDefault": true
        }
      ]
    }
  ],
  "dependencies": [],
  "capabilities": {
    "chat": true,
    "tools": true,
    "vision": true,
    "audio": false,
    "text_embedding": false,
    "image_generator": false,
    "code_interpreter": true
  },
  "tags": [
    "vision",
    "multimodal",
    "instruct",
    "chat",
    "image-understanding"
  ],
  "recommended_parameters": {
    "temperature": 0.7,
    "top_p": 0.8,
    "top_k": 40,
    "repeat_penalty": 1.05,
    "context_size": 32768
  },
  "language_support": [
    "en",
    "zh",
    "ja",
    "ko",
    "vi",
    "th",
    "ar",
    "es",
    "fr",
    "ru",
    "de"
  ],
  "license": "Apache-2.0"
}
