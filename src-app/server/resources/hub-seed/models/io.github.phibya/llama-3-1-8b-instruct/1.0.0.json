{
  "$schema": "/schemas/2026-06-12/model.schema.json",
  "name": "io.github.phibya/llama-3-1-8b-instruct",
  "version": "1.0.0",
  "display_name": "Llama 3.1 8B",
  "description": "Meta's Llama 3.1 8B instruction-tuned model with improved capabilities.",
  "repository": {
    "url": "https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct",
    "source": "huggingface",
    "id": "meta-llama/Llama-3.1-8B-Instruct"
  },
  "sources": [
    {
      "registryType": "huggingface",
      "identifier": "meta-llama/Llama-3.1-8B-Instruct",
      "version": "main",
      "fileFormat": "safetensors",
      "runtimeHint": "mistralrs",
      "contextLength": 8192,
      "environmentVariables": [
        {
          "name": "HUGGINGFACE_API_KEY",
          "description": "Hugging Face access token with download access to this gated model.",
          "isSecret": true,
          "isRequired": true
        }
      ],
      "quantizations": [
        {
          "name": "f16",
          "mainFile": "model.safetensors",
          "sizeGb": 16.1,
          "isDefault": true
        }
      ]
    }
  ],
  "dependencies": [],
  "capabilities": {
    "chat": true,
    "tools": true,
    "vision": false,
    "audio": false,
    "text_embedding": false,
    "image_generator": false,
    "code_interpreter": true
  },
  "tags": [
    "instruct",
    "chat",
    "code",
    "reasoning"
  ],
  "recommended_parameters": {
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "repeat_penalty": 1.1,
    "context_size": 8192
  },
  "language_support": [
    "en",
    "es",
    "fr",
    "de",
    "it",
    "pt",
    "nl",
    "pl"
  ],
  "license": "Meta Custom License"
}
