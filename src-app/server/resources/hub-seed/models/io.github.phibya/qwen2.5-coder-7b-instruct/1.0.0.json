{
  "$schema": "/schemas/2026-06-12/model.schema.json",
  "name": "io.github.phibya/qwen2.5-coder-7b-instruct",
  "version": "1.0.0",
  "display_name": "Qwen2.5-Coder 7B",
  "description": "Alibaba's Qwen2.5-Coder 7B \u2014 code generation, completion, and reasoning across 40+ languages.",
  "repository": {
    "url": "https://huggingface.co/Qwen/Qwen2.5-Coder-7B-Instruct",
    "source": "huggingface",
    "id": "Qwen/Qwen2.5-Coder-7B-Instruct"
  },
  "sources": [
    {
      "registryType": "huggingface",
      "identifier": "Qwen/Qwen2.5-Coder-7B-Instruct",
      "version": "main",
      "fileFormat": "safetensors",
      "runtimeHint": "mistralrs",
      "contextLength": 32768,
      "environmentVariables": [
        {
          "name": "HUGGINGFACE_API_KEY",
          "description": "Hugging Face access token with download access to this gated model.",
          "isSecret": true,
          "isRequired": true
        }
      ],
      "quantizations": [
        {
          "name": "f16",
          "mainFile": "model.safetensors",
          "sizeGb": 15.2,
          "isDefault": true
        }
      ]
    }
  ],
  "dependencies": [],
  "capabilities": {
    "chat": true,
    "tools": true,
    "vision": false,
    "audio": false,
    "text_embedding": false,
    "image_generator": false,
    "code_interpreter": true
  },
  "tags": [
    "code",
    "instruct",
    "chat",
    "reasoning"
  ],
  "recommended_parameters": {
    "temperature": 0.2,
    "top_p": 0.9,
    "top_k": 40,
    "repeat_penalty": 1.05,
    "context_size": 32768
  },
  "language_support": [
    "en",
    "zh"
  ],
  "license": "Apache-2.0"
}
