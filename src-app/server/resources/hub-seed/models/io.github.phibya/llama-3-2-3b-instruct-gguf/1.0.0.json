{
  "$schema": "/schemas/2026-06-12/model.schema.json",
  "name": "io.github.phibya/llama-3-2-3b-instruct-gguf",
  "version": "1.0.0",
  "display_name": "Llama 3.2 3B",
  "description": "Meta's Llama 3.2 3B instruction-tuned model in GGUF format. Multiple quantizations available.",
  "repository": {
    "url": "https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF",
    "source": "huggingface",
    "id": "bartowski/Llama-3.2-3B-Instruct-GGUF"
  },
  "sources": [
    {
      "registryType": "huggingface",
      "identifier": "bartowski/Llama-3.2-3B-Instruct-GGUF",
      "version": "main",
      "fileFormat": "gguf",
      "runtimeHint": "llamacpp",
      "contextLength": 8192,
      "environmentVariables": [
        {
          "name": "HUGGINGFACE_API_KEY",
          "description": "Hugging Face access token with download access to this gated model.",
          "isSecret": true,
          "isRequired": true
        }
      ],
      "quantizations": [
        {
          "name": "q5_k_s",
          "mainFile": "Llama-3.2-3B-Instruct-Q5_K_S.gguf",
          "sizeGb": 1.9,
          "isDefault": true
        },
        {
          "name": "q4_0",
          "mainFile": "Llama-3.2-3B-Instruct-Q4_0.gguf",
          "isDefault": false
        },
        {
          "name": "q4_k_m",
          "mainFile": "Llama-3.2-3B-Instruct-Q4_K_M.gguf",
          "isDefault": false
        },
        {
          "name": "q5_0",
          "mainFile": "Llama-3.2-3B-Instruct-Q5_0.gguf",
          "isDefault": false
        },
        {
          "name": "q5_k_m",
          "mainFile": "Llama-3.2-3B-Instruct-Q5_K_M.gguf",
          "isDefault": false
        },
        {
          "name": "q6_k",
          "mainFile": "Llama-3.2-3B-Instruct-Q6_K.gguf",
          "isDefault": false
        },
        {
          "name": "q8_0",
          "mainFile": "Llama-3.2-3B-Instruct-Q8_0.gguf",
          "isDefault": false
        },
        {
          "name": "fp16",
          "mainFile": "Llama-3.2-3B-Instruct-FP16.gguf",
          "isDefault": false
        }
      ]
    }
  ],
  "dependencies": [],
  "capabilities": {
    "chat": true,
    "tools": true,
    "vision": false,
    "audio": false,
    "text_embedding": false,
    "image_generator": false,
    "code_interpreter": true
  },
  "tags": [
    "instruct",
    "chat",
    "code",
    "gguf",
    "efficient",
    "small"
  ],
  "recommended_parameters": {
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "repeat_penalty": 1.1,
    "context_size": 8192
  },
  "language_support": [
    "en",
    "es",
    "fr",
    "de",
    "it",
    "pt",
    "nl"
  ],
  "license": "Meta Custom License"
}
