# Test Environment Configuration Template
# ==========================================
# Copy this file to .env.test and fill in your actual values:
#   cp .env.test.example .env.test
#
# IMPORTANT: Never commit .env.test to git!

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-xxx

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxx

# Optional: Groq API Key (for OpenAI compatibility testing)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=xxx


# HuggingFace API Configuration
# Get your API key from: https://huggingface.co/settings/tokens
# Required for E2E tests only (optional for basic tests)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub personal access token (classic, no scopes needed for public repos).
# Get from: https://github.com/settings/tokens
# REQUIRED for the llm_model repository-files GitHub auto-detect tests
# (anonymous GitHub API is 60 req/hr per IP and would make them flaky).
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database Configuration
# Default works for local development with docker-compose
# Start PostgreSQL: cd src-web && docker compose up -d
DATABASE_URL=postgresql://postgres:password@127.0.0.1:54321/postgres

# --- Real-LLM test bridge (optional) ---------------------------------------
# Redirect real-LLM test tiers at a local OpenAI/Anthropic-compatible bridge
# (e.g. a self-hosted DeepSeek/Qwen LiteLLM bridge) instead of the paid SaaS
# endpoints. Per-provider override is `<PROVIDER>_BASE_URL` (derived from the
# matching `<PROVIDER>_API_KEY`); `ZIEE_TEST_LLM_BASE_URL` is a global fallback
# applied to every provider. A bridge that wildcard-maps model names needs no
# model-name change. Loopback URLs are allowed (DEV_LOCAL validation policy).
# Example — route Anthropic-path real-LLM tests at a local bridge:
#   ANTHROPIC_API_KEY=sk-local-bridge
#   ANTHROPIC_BASE_URL=http://localhost:4000/v1
# Other providers:
#   OPENAI_BASE_URL=http://localhost:4000
#   GEMINI_BASE_URL=http://localhost:4000
#   GROQ_BASE_URL=http://localhost:4000
# Global fallback (all providers):
#   ZIEE_TEST_LLM_BASE_URL=http://localhost:4000
