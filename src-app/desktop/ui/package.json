{
  "name": "@ziee/desktop-ui",
  "version": "0.1.0",
  "dependencies": {
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "dayjs": "^1.11.20",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.8",
    "katex": "^0.16.47",
    "mermaid": "^11.15.0",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "pdfjs-dist": "^6.1.200",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "react-use": "^17.6.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.3.0",
    "tinycolor2": "^1.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^28.0.0",
    "pg": "^8.21.0",
    "selenium-webdriver": "^4.27.0",
    "ts-morph": "^28.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:nocheck": "vite build",
    "check": "tsc && npm run lint:guardrails && npm run lint:colors && npm run lint:settings-field && npm run lint:adjacent-inline && npm run lint:icon-action && npm run lint:logical-direction && npm run lint:tooltip-placement && npm run check:kit-manifest && npm run check:testid-registry && npm run check:design-spec && npm run check:gallery-coverage && npm run check:gallery-crawl && npm run gallery:check-fixtures && npm run check:state-matrix && npm run check:overlay-registry",
    "lint:guardrails": "biome lint --only=style/noRestrictedImports src",
    "lint:colors": "node ../../ui/scripts/lint-hardcoded-colors.mjs",
    "lint:settings-field": "node ../../ui/scripts/lint-settings-field.mjs",
    "lint:adjacent-inline": "node ../../ui/scripts/lint-adjacent-inline.mjs",
    "lint:icon-action": "node scripts/lint-icon-action.mjs",
    "lint:logical-direction": "node ../../ui/scripts/lint-logical-direction.mjs",
    "lint:tooltip-placement": "node ../../ui/scripts/lint-tooltip-placement.mjs",
    "check:kit-manifest": "node ../../ui/scripts/gen-kit-manifest.mjs --check",
    "check:testid-registry": "node ../../ui/scripts/gen-testid-registry.mjs --check",
    "check:design-spec": "node ../../ui/scripts/gen-design-spec.mjs --check",
    "gallery:geometry": "node scripts/gallery-geometry-audit.mjs",
    "gallery:geometry:gate": "node scripts/gallery-geometry-audit.mjs --gate",
    "gallery:affordance": "node scripts/affordance-audit.mjs",
    "detector:acceptance": "node scripts/detector-acceptance.mjs",
    "gen:crop-review": "node scripts/gen-crop-review-manifests.mjs",
    "gen:overlay-registry": "node scripts/gen-overlay-registry.mjs",
    "check:overlay-registry": "node scripts/gen-overlay-registry.mjs --check",
    "gen:gallery-coverage": "node scripts/gen-gallery-coverage.mjs",
    "check:gallery-coverage": "node scripts/gen-gallery-coverage.mjs --check",
    "gen:state-matrix": "node scripts/gen-state-matrix.mjs",
    "check:state-matrix": "node scripts/gen-state-matrix.mjs --check",
    "gen:gallery-crawl": "node scripts/gen-crawl-cassette.mjs",
    "check:gallery-crawl": "node scripts/gen-crawl-cassette.mjs --check",
    "gallery:record": "node scripts/record-gallery-fixtures.mjs",
    "gallery:check-fixtures": "node scripts/check-gallery-fixtures.mjs",
    "gallery:screenshots": "node scripts/capture-gallery-screenshots.mjs",
    "gallery:states": "node scripts/capture-gallery-states.mjs",
    "gallery:runtime": "node scripts/runtime-health.mjs",
    "gate:ui": "node scripts/gate-ui.mjs",
    "dev": "vite",
    "format": "biome format --write ./src",
    "format:check": "biome check ./src",
    "format:lint": "npx ts-path-alias-fixer && biome lint --write --unsafe ./src",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:gallery": "playwright test -c playwright.gallery.config.ts",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:tauri-driver": "node tests/tauri-driver/smoke.mjs",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts"
  },
  "type": "module"
}
