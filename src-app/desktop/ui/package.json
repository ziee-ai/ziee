    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2.4.0",
    "antd": "^6.0.0",
    "dayjs": "^1.11.13",
    "highlight.js": "^11.11.1",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^10.1.1",
    "katex": "^0.16.22",
    "mermaid": "^11.9.0",
    "overlayscrollbars": "^2.12.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
