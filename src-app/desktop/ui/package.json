{
  "name": "@ziee/desktop-ui",
  "version": "0.1.0",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "dayjs": "^1.11.20",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.8",
    "mermaid": "^11.15.0",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.1",
    "react-use": "^17.6.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.3.0",
    "tinycolor2": "^1.6.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^28.0.0",
    "pg": "^8.21.0",
    "selenium-webdriver": "^4.27.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:nocheck": "vite build",
    "check": "npm run generate-openapi && tsc",
    "dev": "vite",
    "format": "biome format --write ./src",
    "format:check": "biome check ./src",
    "format:lint": "npx ts-path-alias-fixer && biome lint --write --unsafe ./src",
    "generate-openapi": "npx tsx openapi/generate-endpoints.ts",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:tauri-driver": "node tests/tauri-driver/smoke.mjs",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts"
  },
  "type": "module"
}
