{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "experimentalDecorators": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping - resolves imports for type checking
       Vite uses its own resolution at build time */
    "baseUrl": ".",
    /* TS 6 deprecates baseUrl (removed in TS 7). We still need it
       because the path-mapping below uses paths relative to baseUrl;
       silence the deprecation until we migrate to a baseUrl-free
       path layout. */
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/api-client/types": ["./src/api-client/types.ts"],
      "@ziee/desktop": ["./src"],
      "@ziee/desktop/*": ["./src/*"],
      "@/*": ["../../ui/src/*"],
      "@ziee/ui-core": ["../../ui/src/index.ts"],
      "@ziee/ui-core/*": ["../../ui/src/*"],
      "@ziee/kit": ["../../../sdk/packages/kit/src/index.ts"],
      "@ziee/kit/*": ["../../../sdk/packages/kit/src/*"],
      "@ziee/framework": ["../../../sdk/packages/framework/src/index.ts"],
      "@ziee/framework/api-client": [
        "../../../sdk/packages/framework/src/api-client/index.ts"
      ],
      "@ziee/framework/*": ["../../../sdk/packages/framework/src/*"],
      "@ziee/shell": ["../../../sdk/packages/shell/src/index.ts"],
      "@ziee/shell/*": ["../../../sdk/packages/shell/src/*"],
      "@ziee/gallery": ["../../../sdk/packages/gallery/src/index.ts"],
      "@ziee/gallery/*": ["../../../sdk/packages/gallery/src/*"],
      "csstype": ["./node_modules/csstype"]
    }
  },
  "include": ["src", "tests", "../../ui/src"],
  "exclude": ["node_modules", "dist", "../../ui/node_modules"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
