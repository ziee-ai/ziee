{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "experimentalDecorators": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping - resolves imports for type checking
       Vite uses its own resolution at build time */
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../ui/src/*"],
      "@ziee/ui-core": ["../../ui/src/index.ts"],
      "@ziee/ui-core/*": ["../../ui/src/*"],
      "csstype": ["./node_modules/csstype"]
    }
  },
  "include": ["src", "tests", "../../ui/src"],
  "exclude": ["node_modules", "dist", "../../ui/node_modules"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
