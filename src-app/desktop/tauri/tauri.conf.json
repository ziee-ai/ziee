{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ziee Chat",
  "version": "0.1.0",
  "identifier": "com.ziee.chat",
  "build": {
    "beforeDevCommand": "npm run dev --workspace=@ziee/desktop-ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:nocheck --workspace=@ziee/desktop-ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ziee Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
