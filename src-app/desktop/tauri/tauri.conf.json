{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ziee",
  "mainBinaryName": "ziee",
  "version": "0.1.0",
  "identifier": "com.ziee.chat",
  "build": {
    "beforeDevCommand": "npm run dev --workspace=@ziee/desktop-ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../../ui && npm run build && cd ../desktop/ui && npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://ziee-ai.github.io/ziee/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCMTZEQ0VBMDBFOEU5RkUKUldUKzZlZ0E2dHdXZTlLSytNRnJlWlUyNDczM1VHbmEzTUxHcHo4OGxLalpTc3FMVXVmbVBnTGYK"
    }
  }
}
