{
	"$schema": "https://biomejs.dev/schemas/2.1.2/schema.json",
	"extends": ["../../sdk/packages/config/biome.base.json"],
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/*.desktop.tsx", "!**/*.desktop.ts"]
	},
	"overrides": [
		{
			"includes": ["**/*.{js,jsx,ts,tsx}"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"antd": "antd is removed — import UI from '@/components/ui' (the kit).",
									"@ant-design/icons": "Use lucide-react icons (re-exported via the kit) instead of @ant-design/icons.",
									"antd/es/form": "antd is removed — use the kit Form/FormField from '@/components/ui'."
								}
							}
						}
					}
				}
			}
		},
		{
			"includes": [
				"**/*.{ts,tsx,jsx}",
				"!**/components/ui/kit/**",
				"!**/components/ui/shadcn/**",
				"!**/tests/**",
				"!**/dev/gallery/DefectRepro.tsx",
				"!**/dev/gallery/__detector_fixtures__/**"
			],
			"plugins": [
				"./biome-plugins/no-raw-interactive-elements.grit",
				"./biome-plugins/no-store-internal-state.grit"
			]
		}
	]
}
