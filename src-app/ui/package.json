{
  "name": "@ziee/ui-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api-client/*": "./src/api-client/*",
    "./components/*": "./src/components/*",
    "./modules/*": "./src/modules/*",
    "./themes/*": "./src/themes/*",
    "./utils/*": "./src/utils/*",
    "./stores/*": "./src/stores/*",
    "./core/*": "./src/core/*"
  },
  "scripts": {
    "dev": "vite",
    "check": "npm run generate-openapi && tsc && npx --no-install antd doctor && npx --no-install antd lint src",
    "build": "npm run generate-openapi && tsc && vite build",
    "preview": "vite preview",
    "format": "biome format --write ./src",
    "format:check": "biome check ./src",
    "format:lint": "npx ts-path-alias-fixer && biome lint --write --unsafe ./src",
    "generate-openapi": "npx tsx openapi/generate-endpoints.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "test:db:start": "node scripts/test-db.js start",
    "test:db:stop": "node scripts/test-db.js stop",
    "test:db:clean": "node scripts/test-db.js clean",
    "test:db:logs": "node scripts/test-db.js logs",
    "build:nocheck": "npm run generate-openapi && vite build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tauri-apps/api": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.4.0",
    "antd": "^6.0.0",
    "dayjs": "^1.11.13",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "immer": "^11.1.8",
    "mermaid": "^11.9.0",
    "overlayscrollbars": "^2.12.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.7.1",
    "react-use": "^17.6.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.1.11",
    "tinycolor2": "^1.6.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.4.3",
    "@axe-core/playwright": "^4.10.0",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2.7.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "pg": "^8.13.3",
    "typescript": "~6.0",
    "uuid": "^14.0.0",
    "vite": "^8.0.14"
  }
}
