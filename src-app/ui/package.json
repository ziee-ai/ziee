  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && vite build",
    "build:nocheck": "vite build",
    "check": "tsc && npm run lint:guardrails && npm run lint:colors && npm run check:kit-manifest && npm run check:testid-registry",
    "lint:guardrails": "biome lint --only=style/noRestrictedImports src",
    "lint:colors": "node scripts/lint-hardcoded-colors.mjs",
    "check:kit-manifest": "node scripts/gen-kit-manifest.mjs --check",
    "gen:kit-manifest": "node scripts/gen-kit-manifest.mjs",
    "check:testid-registry": "node scripts/gen-testid-registry.mjs --check",
    "gen:testid-registry": "node scripts/gen-testid-registry.mjs",
    "dev": "vite",
    "format": "biome format --write ./src",
    "format:check": "biome check ./src",
    "format:lint": "npx ts-path-alias-fixer && biome lint --write --unsafe ./src",
    "preview": "vite preview",
    "test:db:clean": "node scripts/test-db.js clean",
    "test:db:logs": "node scripts/test-db.js logs",
    "test:db:start": "node scripts/test-db.js start",
    "test:db:stop": "node scripts/test-db.js stop",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:visual:list": "playwright test -c playwright.visual.config.ts --list",
    "visual:judge": "node scripts/visual-judge.mjs"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
