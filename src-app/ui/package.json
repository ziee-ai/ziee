    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api-client/*": "./src/api-client/*",
    "./components/*": "./src/components/*",
    "./modules/*": "./src/modules/*",
    "./themes/*": "./src/themes/*",
    "./utils/*": "./src/utils/*",
    "./stores/*": "./src/stores/*",
    "./core/*": "./src/core/*"
