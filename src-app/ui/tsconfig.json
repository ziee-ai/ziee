{
  "extends": "../../sdk/packages/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "paths": {
      "@/*": ["./src/*"],
      "@ziee/kit": ["../../sdk/packages/kit/src/index.ts"],
      "@ziee/kit/*": ["../../sdk/packages/kit/src/*"],
      "@ziee/framework": ["../../sdk/packages/framework/src/index.ts"],
      "@ziee/framework/api-client": [
        "../../sdk/packages/framework/src/api-client/index.ts"
      ],
      "@ziee/framework/*": ["../../sdk/packages/framework/src/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.desktop.tsx",
    "**/*.desktop.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
